# ============================================================================
# WON-MALLY - Variables d'environnement globales (docker-compose)
# Copier ce fichier en .env et renseigner des valeurs reelles avant deploiement.
# Ne JAMAIS commiter le fichier .env reel dans Git.
# ============================================================================

# Base de donnees
DB_NAME=wonmally_db
DB_USERNAME=wonmally
DB_PASSWORD=changeme
DB_ROOT_PASSWORD=changeme_root

# JWT (256 bits minimum - generer avec : openssl rand -base64 64)
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_minimum_256_bits_secret_key_required
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme
