# ============================================================================
# WON-MALLY API - Dockerfile de DEVELOPPEMENT (hot-reload)
# Ne pas utiliser en production - voir Dockerfile pour le build de prod
# ============================================================================
FROM maven:3.9-eclipse-temurin-17
WORKDIR /app
COPY pom.xml .
RUN mvn dependency:go-offline -B
EXPOSE 8080
ENTRYPOINT ["mvn", "spring-boot:run"]
